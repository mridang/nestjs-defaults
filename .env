# NOTE: This file is marked as 'assume unchanged' in Git to prevent accidental
# commits of local configuration. It was ignored with
# `git update-index --assume-unchanged .env`. To stage changes to it, first run
# `git update-index --no-assume-unchanged .env`.

################################################################################
# Service & cloud metadata
################################################################################
# These variables describe the running service and are attached to every log
# line as Elastic Common Schema (ECS) fields. Managed runtimes set them from
# their own environment or bindings; any left unset simply omit the
# corresponding ECS field.

# Identifier of the service instance (service.id).
SERVICE_ID=

# Human-readable service name (service.name).
SERVICE_NAME=foobar

# Service category (service.type).
SERVICE_TYPE=

# Service version (service.version).
SERVICE_VERSION=1

# Cloud provider, e.g. 'cloudflare' (cloud.provider).
CLOUD_PROVIDER=cloudflare

# Region or point of presence serving the request (cloud.region).
CLOUD_REGION=

# Remaining cloud.* fields, populated on host-based runtimes such as containers
# and left unset on serverless isolates such as Cloudflare Workers.
CLOUD_ACCOUNT_ID=
CLOUD_ACCOUNT_NAME=
CLOUD_AVAILABILITY_ZONE=
CLOUD_INSTANCE_ID=
CLOUD_INSTANCE_NAME=
CLOUD_MACHINE_TYPE=
CLOUD_SERVICE_NAME=

################################################################################
# Sentry
################################################################################
# Sentry error tracking. When SENTRY_DSN is empty the SDK sends nothing.
# https://docs.sentry.io/concepts/key-terms/dsn-explainer/
SENTRY_DSN=
